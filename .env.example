FLASK_ENV=development

# Obrigatório em produção (veja src/settings/_base.py)
SECRET_KEY=altere-em-producao
JWT_SECRET_KEY=altere-em-producao

# App local (host localhost). Use postgresql+psycopg2 (sync). +asyncpg exige outro pacote e não é usado aqui.
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://hub:hub@localhost:5432/hub_banking

# Docker Compose: sobrepõe com host do serviço Postgres (ver docker/README.md)
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://hub:hub@db:5432/hub_banking

DOCS_DEV=/docs

# Interpolação no docker-compose.yml (opcional; há defaults no YAML)
POSTGRES_USER=hub
POSTGRES_PASSWORD=hub
POSTGRES_DB=hub_banking
POSTGRES_PORT=5432
API_PORT=8001

# Gunicorn (produção / container)
# GUNICORN_BIND=0.0.0.0:8001
# GUNICORN_WORKERS=4

# Middleware só em desenvolvimento (manage.py)
DISABLE_DEV_USER_MIDDLEWARE=0
DEV_MOCK_USER_ID=1
DEV_MOCK_USER_EMAIL=hrpbs@teste.com
