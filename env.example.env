#############################################
# General environment variables
#############################################
TZ=UTC
APP_NAME=


#############################################
# FastAPI environment variables
#############################################
API_VERSION=
BACKEND_CORS_ORIGINS=
DEBUG=
API_PORT=
API_DEBUG_PORT=
API_BASE_URL=
INSTALL_DEV=
APP_NAME_FOR_CALLBACKS=

# JWT (HS256): mínimo ~32 caracteres; vazio gera InsecureKeyLengthWarning no PyJWT
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=36000

# Conexão ao banco de dados
SQLALCHEMY_DATABASE_URI=
POSTGRES_SCHEMA=hub-banking-platform

#############################################
# Docker / Docker Compose (make build, make up)
#############################################
# Usado pelo docker-compose. Valores padrão no compose caso vazios.
DATABASE_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=hub-banking-platform
POSTGRES_PORT=5432
POSTGRES_DB=hub-banking-platform
POSTGRES_SCHEMA=hub-banking-platform
ALLOWED_HOSTS=*


#############################################
# AWS S3 (Upload de imagens)
#############################################
AWS_REGION=
AWS_S3_BUCKET_NAME=
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_ENDPOINT_URL=
AWS_S3_PUBLIC_READ=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

S3_UPLOAD_MAX_SIZE_MB=5
S3_ALLOWED_IMAGE_CONTENT_TYPES=image/jpeg,image/png,image/webp
